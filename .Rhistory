set.seed(414)
W <- 2*log((choose(170, 8) * ((1 - 0.9506173)
/(2 - 0.9506173))^8 *
(1 - (1 - 0.9506173)/(2 - 0.9506173))^162)/
(choose(170, 8) * ((1 - 0.3)/(2 - 0.3))^8 *
(1 - (1 - 0.3)/(2 - 0.3))^162))
n <- 30
B <- 10000
W_ast <- numeric(B)
for (i in 1:B) {
x <- runif(n, 0, 1)
mle <- -n/sum(log(x)) - 1
W_ast[i] <- 2 * (n*log(mle+1) + mle*sum(log(x)))
}
hist(W_ast, breaks=50, main="Distribution of LRT statistic", xlab=expression(W))
p_val <- sum(W_ast > W)/B
p_val
x <- runif(100)
n <- length(x)
loglik_binom <- function(psi, n, x){
log(choose(n, x)) + x * log(1 - psi) - x * log(2 - psi) - (n - x) * log(2 - psi)
}
ml <- maxLik2(loglik=loglik_binom,
start=0.5, n=n, x=x)
